generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id                       Int           @id @default(autoincrement())
  role                     Role          @default(client)
  nom                      String
  prenom                   String
  email                    String        @unique
  motPasse                 String
  telephone                String
  telephoneSecondaire      String?
  adresse                  String?
  photo                    String?
  dateInscription          DateTime      @default(now())
  otpCode                  String?
  otpExpires               DateTime?
  isVerified               Boolean       @default(false)
  blocked                  Boolean       @default(false)
  resetPasswordToken       String?
  resetPasswordExpires     DateTime?
  verificationToken        String?
  verificationTokenExpires DateTime?
  deleted                  Boolean       @default(false)
  deletedAt                DateTime?
  temoignages              String[]      @default([])
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  contracts                Contract[]
  contractsValidated       Contract[]    @relation("ContractValidatedBy")
  reservations             Reservation[]

  @@map("users")
}

model Agency {
  id          Int       @id @default(autoincrement())
  name        String
  address     String
  city        String
  postalCode  String
  country     String
  phone       String
  email       String
  manager     String?
  description String?
  logo        String?
  location    Json?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  vehicles    Vehicle[]

  @@map("agencies")
}

model Vehicle {
  id              Int           @id @default(autoincrement())
  carrosserie     String
  modele          String
  marque          String
  transmission    String
  prix            Float
  photos          String[]      @default([])
  immatriculation String        @unique
  agenceId        Int
  deleted         Boolean       @default(false)
  deletedAt       DateTime?
  disponible      Boolean       @default(true)
  promotionCandidate Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  contracts       Contract[]
  reservations    Reservation[]
  agency          Agency        @relation(fields: [agenceId], references: [id])

  @@index([marque])
  @@index([modele])
  @@index([agenceId])
  @@index([deleted])
  @@map("vehicles")
}

model Reservation {
  id                Int               @id @default(autoincrement())
  vehicleId         Int
  clientId          Int
  dateDebut         DateTime
  dateFin           DateTime
  statut            StatutReservation @default(en_attente)
  numeroReservation String            @unique
  promotionId       Int?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  paiements         Paiement[]
  client            User              @relation(fields: [clientId], references: [id])
  promotion         Promotion?        @relation(fields: [promotionId], references: [id])
  vehicle           Vehicle           @relation(fields: [vehicleId], references: [id])

  @@map("reservations")
}

model Contract {
  id                  Int            @id @default(autoincrement())
  userId              Int
  vehicleId           Int?
  dateDebut           DateTime
  dateFin             DateTime
  statut              ContractStatus @default(pending)
  montantTotal        Float
  acompteVerse        Float          @default(0)
  conditionsSpeciales String?
  commentaires        String?
  dateValidation      DateTime?
  validePar           Int?
  agenceNom           String?
  agenceAdresse       String?
  agenceTelephone     String?
  agenceEmail         String?
  agenceLogo          String?
  deleted             Boolean        @default(false)
  deletedAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  user                User           @relation(fields: [userId], references: [id])
  valideParUser       User?          @relation("ContractValidatedBy", fields: [validePar], references: [id])
  vehicle             Vehicle?       @relation(fields: [vehicleId], references: [id])

  @@index([userId])
  @@index([vehicleId])
  @@index([statut])
  @@index([deleted])
  @@index([createdAt])
  @@map("contracts")
}

model Paiement {
  id              Int             @id @default(autoincrement())
  reservationId   Int
  nom             String          @default("Client inconnu")
  email           String          @default("")
  montant         Float
  statut          StatutPaiement
  methodePaiement MethodePaiement
  datePaiement    DateTime        @default(now())
  transactionId   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  reservation     Reservation     @relation(fields: [reservationId], references: [id])

  @@map("paiements")
}

model Promotion {
  id                 Int             @id @default(autoincrement())
  titre              String
  description        String?
  type               TypePromotion
  valeur             Float
  dateDebut          DateTime
  dateFin            DateTime
  statut             StatutPromotion @default(active)
  vehiculesIds       Int[]           @default([])
  codesPromo         String[]        @default([])
  utilisationMax     Int             @default(0)
  utilisations       Int             @default(0)
  dureeMinLocation   Int             @default(1)
  montantMinCommande Float           @default(0)
  deleted            Boolean         @default(false)
  deletedAt          DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  reservations       Reservation[]

  @@map("promotions")
}


model Post {
  id            Int        @id @default(autoincrement())
  title         String
  content       String
  slug          String     @unique
  excerpt       String?
  author        String?
  status        PostStatus @default(draft)
  tags          String[]   @default([])
  publishedAt   DateTime?
  featuredImage String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("posts")
}

model Contact {
  id          Int           @id @default(autoincrement())
  nom         String
  email       String
  telephone   String?
  sujet       String
  message     String
  status      ContactStatus @default(pending)
  response    String?
  respondedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("contacts")
}

enum Role {
  admin
  client
  entreprise
  tourist
  testeur
}

enum StatutReservation {
  en_attente
  validee
  en_cours
  terminee
  annulee
}

enum ContractStatus {
  pending
  approved
  rejected
  cancelled
}

enum StatutPaiement {
  reussi
  echoue
}

enum MethodePaiement {
  CARTE
  TMONEY
  FLOOZ
}

enum TypePromotion {
  pourcentage
  montant_fixe
}

enum StatutPromotion {
  active
  inactive
  expired
}

enum PostStatus {
  draft
  published
}

enum ContactStatus {
  pending
  responded
}
